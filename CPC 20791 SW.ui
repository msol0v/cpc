  </property>
  <property name="windowTitle">
   <string>MainWindow</string>
  </property>
  <property name="styleSheet">
   <string notr="true">/* ============================================
   LIGHT &amp; AIRY THEME with Inter Font
   Blue Accents
   ============================================ */

* {
    font-family: 'Inter', 'Segoe UI', 'Roboto', 'Arial', sans-serif;
    font-size: 12px;
}

/* ========== ГЛАВНОЕ ОКНО ========== */
QMainWindow, QDialog {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                               stop:0 #fafcff,
                               stop:1 #f0f4fa);
}

QWidget {
    background: #dbdbdb;
}

QTabWidget::pane {
    background: #dbdbdb; 
   /* border: 1px solid #e6ecf5;*/
    border-radius: 0 16px 16px 16px;
    padding: 24px;
    margin: 0px;
}

QTabBar {
    background: transparent;
    qproperty-drawBase: 0;
    qproperty-expanding: 0;
}

QTabBar::tab {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                               stop:0 #f5f9ff,
                               stop:1 #e9f0f7);
    color: #4a5b68;
    font-size: 13px;
    font-weight: 500;
    min-width: 100px;
    max-width: 200px;
    padding: 10px 20px;
    margin-right: 2px;
    border: none;
    border-top-left-radius: 12px;
    border-top-right-radius: 12px;
    word-wrap: break-word;
    white-space: nowrap;
}

QTabBar::tab[longtext=&quot;true&quot;] {
    white-space: normal;
    min-width: 60px;
    max-width: 150px;
    padding: 10px 12px;
}

QTabBar::tab:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                               stop:0 #ffffff,
                               stop:1 #f5f9ff);
    color: #3498db;
}

QTabBar::tab:selected {
    background: white;
    color: #2980b9;
    font-weight: 600;
    border-bottom: 3px solid #3498db;
    margin-bottom: -1px;
}

QTabBar::tab:first {
    margin-left: 20px;
}

QTabBar::tab:last {
    margin-right: 0;
}

/* ========== GROUP BOX ========== */
QGroupBox {
    background: white;
    border: 1px solid #e6ecf5;
    border-radius: 16px;
    margin-top: 16px;
    padding-top: 24px;
    padding-bottom: 16px;
    padding-left: 16px;
    padding-right: 16px;
    color: #2c3e50;
    font-weight: 500;
}

QGroupBox::title {
    subcontrol-origin: padding;
    subcontrol-position: top left;
    left: 16px;
    top: -12px;
    padding: 4px 16px;
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                               stop:0 #3498db,
                               stop:1 #2980b9);
    border-radius: 20px;
    border: none;
    color: white;
    font-size: 11px;
    font-weight: 600;
    letter-spacing: 0.3px;
    text-transform: uppercase;
}

QGroupBox QWidget {
    background: transparent;
}

QGroupBox#top_title {
    margin-top: 0px;
    padding-top: 32px;
}

QGroupBox#top_title::title {
    subcontrol-origin: padding;
    subcontrol-position: top center;
    top: -16px;
    padding: 6px 24px;
}

QGroupBox#inside_title {
    margin-top: 0px;
    padding-top: 16px;
}

QGroupBox#inside_title::title {
    subcontrol-origin: padding;
    subcontrol-position: top left;
    left: 16px;
    top: -8px;
    padding: 3px 12px;
    font-size: 10px;
}

/* ========== RADIO BUTTON ========== */
QRadioButton {
    color: #2c3e50;
    font-size: 13px;
    spacing: 12px;
    padding: 6px 4px;
    background: transparent;
}

QRadioButton::indicator {
    width: 20px;
    height: 20px;
    border-radius: 10px;
    border: 2px solid #d0d9e4;
    background: white;
}

QRadioButton::indicator:hover {
    border: 2px solid #74b9ff;
    background: #f8fcff;
}

QRadioButton::indicator:checked {
    border: 2px solid #3498db;
    background: qradialgradient(cx:0.5, cy:0.5, radius:0.6,
                                fx:0.5, fy:0.5,
                                stop:0 #74b9ff,
                                stop:0.7 #3498db,
                                stop:1 #2980b9);
}

QRadioButton:checked {
    color: #1a2634;
    font-weight: 600;
}

/* ========== PUSH BUTTON ========== */
QPushButton {
    background: white;
    color: #2c3e50;
    border: 1px solid #d8e1ec;
    border-radius: 10px;
    padding: 10px 24px;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.2px;
}

QPushButton:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                               stop:0 #f0f8ff,
                               stop:1 #e5f0ff);
    border: 1px solid #3498db;
    color: #2980b9;
}

QPushButton:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                               stop:0 #e5f0ff,
                               stop:1 #d8eaff);
    padding-top: 11px;
    padding-bottom: 9px;
}

QPushButton:disabled {
    background: #f8fafc;
    color: #a0b3c2;
    border: 1px solid #e6ecf5;
}

QPushButton:default {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                               stop:0 #3498db,
                               stop:1 #2980b9);
    border: none;
    color: white;
    font-weight: 600;
}

QPushButton:default:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                               stop:0 #5dade2,
                               stop:1 #3498db);
}

/* ========== LABEL ========== */
QLabel {
    color: #2c3e50;
    background: transparent;
    padding: 2px;
    font-size: 13px;
}

QLabel#title {
    color: #1a2634;
    font-size: 20px;
    font-weight: 700;
    letter-spacing: -0.3px;
    padding-bottom: 12px;
}

QLabel#header {
    color: #3498db;
    font-size: 15px;
    font-weight: 600;
    padding: 8px 0;
}

QLabel#value {
    color: #2980b9;
    font-weight: 700;
    font-size: 17px;
    background: #f0f8ff;
    padding: 6px 16px;
    border-radius: 24px;
    border: 1px solid #d4e6f1;
}

QLabel#accent {
    color: #3498db;
    font-weight: 600;
}

QLabel#info {
    color: #7f8c8d;
    font-size: 12px;
}

/* ========== LCD NUMBER ========== */
QLCDNumber {
    background: white;
    color: #1a2634;
    border: 1px solid #e6ecf5;
    border-radius: 12px;
    padding: 8px;
}

QLCDNumber#big {
    font-size: 28px;
    min-height: 60px;
    max-height: 80px;
    color: #2980b9;
    border: 2px solid #3498db;
}

/* ========== TOOLTIPS ========== */
QToolTip {
    background: #2c3e50;
    color: white;
    border: none;
    border-radius: 8px;
    padding: 10px 16px;
    font-size: 12px;
    font-family: 'Inter', 'Segoe UI', sans-serif;
}

/* ========== SCROLL BARS ========== */
QScrollBar:vertical {
    background: #f5f9ff;
    width: 14px;
    border-radius: 7px;
    margin: 0px;
}

QScrollBar::handle:vertical {
    background: #cbd5e0;
    min-height: 30px;
    border-radius: 7px;
    margin: 2px;
}

QScrollBar::handle:vertical:hover {
    background: #3498db;
}

QScrollBar:horizontal {
    background: #f5f9ff;
    height: 14px;
    border-radius: 7px;
}

QScrollBar::handle:horizontal {
    background: #cbd5e0;
    min-width: 30px;
    border-radius: 7px;
    margin: 2px;
}

QScrollBar::handle:horizontal:hover {
    background: #3498db;
}

/* ========== COMBOBOX ========== */
QComboBox {
    background: white;
    color: #2c3e50;
    border: 1px solid #d8e1ec;
    border-radius: 10px;
    padding: 10px 16px;
    font-size: 13px;
}

QComboBox:hover {
    border: 1px solid #3498db;
    background: #f0f8ff;
}

QComboBox:focus {
    border: 1px solid #2980b9;
    background: white;
}

QComboBox::drop-down {
    subcontrol-origin: padding;
    subcontrol-position: top right;
    width: 30px;
    border-left: 1px solid #d8e1ec;
    border-top-right-radius: 10px;
    border-bottom-right-radius: 10px;
}

QComboBox::down-arrow {
    image: none;
    border-left: 5px solid transparent;
    border-right: 5px solid transparent;
    border-top: 5px solid #3498db;
    width: 0;
    height: 0;
    margin-right: 8px;
}

QComboBox QAbstractItemView {
    background: white;
    color: #2c3e50;
    border: 1px solid #d8e1ec;
    border-radius: 8px;
    selection-background-color: #e1f0fa;
    selection-color: #2980b9;
    outline: 0;
    padding: 4px;
}

/* ========== LINE EDIT ========== */
QLineEdit, QTextEdit, QPlainTextEdit {
    background: white;
    color: #2c3e50;
    border: 1px solid #d8e1ec;
    border-radius: 10px;
    padding: 10px 14px;
    font-size: 13px;
    selection-background-color: #d4e6f1;
    selection-color: #1a2634;
}

QLineEdit:focus, QTextEdit:focus, QPlainTextEdit:focus {
    border: 1px solid #3498db;
    background: #fafcff;
}

QLineEdit:hover, QTextEdit:hover, QPlainTextEdit:hover {
    border: 1px solid #74b9ff;
}

/* ========== CHECKBOX ========== */
QCheckBox {
    color: #2c3e50;
    font-size: 13px;
    spacing: 10px;
}

QCheckBox::indicator {
    width: 20px;
    height: 20px;
    border-radius: 6px;
    border: 2px solid #d0d9e4;
    background: white;
}

QCheckBox::indicator:hover {
    border: 2px solid #74b9ff;
    background: #f0f8ff;
}

QCheckBox::indicator:checked {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                               stop:0 #3498db,
                               stop:1 #2980b9);
    border: 2px solid #3498db;
}

QCheckBox:checked {
    color: #1a2634;
    font-weight: 600;
}

/* ========== SPINBOX ========== */
QSpinBox, QDoubleSpinBox {
    background: white;
    color: #2c3e50;
    border: 1px solid #d8e1ec;
    border-radius: 10px;
    padding: 8px 12px;
    font-size: 13px;
}

QSpinBox:hover, QDoubleSpinBox:hover {
    border: 1px solid #3498db;
}

QSpinBox:focus, QDoubleSpinBox:focus {
    border: 1px solid #2980b9;
}

/* ========== PROGRESS BAR ========== */
QProgressBar {
    background: #edf2f7;
    border: 1px solid #d8e1ec;
    border-radius: 10px;
    height: 24px;
    text-align: center;
    color: #2c3e50;
    font-size: 12px;
    font-weight: 600;
}

QProgressBar::chunk {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                               stop:0 #74b9ff,
                               stop:1 #3498db);
    border-radius: 8px;
}

/* ========== SLIDER ========== */
QSlider::groove:horizontal {
    background: #edf2f7;
    border: 1px solid #d8e1ec;
    height: 8px;
    border-radius: 4px;
}

QSlider::handle:horizontal {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                               stop:0 #ffffff,
                               stop:1 #f5f9ff);
    border: 2px solid #3498db;
    width: 22px;
    height: 22px;
    margin: -7px 0;
    border-radius: 11px;
}

QSlider::handle:horizontal:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                               stop:0 #74b9ff,
                               stop:1 #3498db);
    border: 2px solid #2980b9;
}

QSlider::sub-page:horizontal {
    background: qlineargradient(x1:0, y1:0, x2:1, y2:0,
                               stop:0 #74b9ff,
                               stop:1 #3498db);
    border-radius: 4px;
}

/* ========== TABLE VIEW ========== */
QTableView {
    background: white;
    border: 1px solid #e6ecf5;
    border-radius: 12px;
    padding: 4px;
    gridline-color: #edf2f7;
    color: #2c3e50;
}

QTableView::item {
    padding: 10px;
    border-bottom: 1px solid #f0f4fa;
}

QTableView::item:selected {
    background: #e1f0fa;
    color: #2980b9;
}

QHeaderView::section {
    background: #f5f9ff;
    color: #2c3e50;
    border: none;
    border-bottom: 2px solid #3498db;
    padding: 12px;
    font-weight: 600;
    font-size: 12px;
}

/* ========== LIST VIEW ========== */
QListView {
    background: white;
    border: 1px solid #e6ecf5;
    border-radius: 12px;
    padding: 8px;
    color: #2c3e50;
}

QListView::item {
    padding: 10px 14px;
    border-radius: 8px;
}

QListView::item:hover {
    background: #f0f8ff;
    color: #2980b9;
}

QListView::item:selected {
    background: #3498db;
    color: white;
}

/* ========== MENU BAR ========== */
QMenuBar {
    background: white;
    border-bottom: 1px solid #e6ecf5;
    padding: 4px;
}

QMenuBar::item {
    background: transparent;
    color: #2c3e50;
    padding: 10px 18px;
    border-radius: 8px;
    font-size: 13px;
}

QMenuBar::item:selected {
    background: #f0f8ff;
    color: #3498db;
}

QMenu {
    background: white;
    border: 1px solid #e6ecf5;
    border-radius: 12px;
    padding: 8px;
}

QMenu::item {
    padding: 10px 28px;
    border-radius: 8px;
    color: #2c3e50;
    font-size: 13px;
}

QMenu::item:selected {
    background: #f0f8ff;
    color: #3498db;
}

QMenu::separator {
    height: 1px;
    background: #e6ecf5;
    margin: 8px 16px;
}

/* ========== STATUS BAR ========== */
QStatusBar {
    background: white;
    border-top: 1px solid #e6ecf5;
    color: #7f8c8d;
    padding: 8px;
    font-size: 12px;
}

/* ========== SPLITTER ========== */
QSplitter::handle {
    background: #e6ecf5;
    border-radius: 2px;
}

QSplitter::handle:hover {
    background: #3498db;
}

/* ========== LIST WIDGET ========== */
QListWidget {
    background: white;
    border: 1px solid #e6ecf5;
    border-radius: 12px;
    padding: 8px;
    color: #2c3e50;
}

QListWidget::item {
    padding: 10px 14px;
    border-radius: 8px;
}

QListWidget::item:hover {
    background: #f0f8ff;
    color: #2980b9;
}

QListWidget::item:selected {
    background: #3498db;
    color: white;
}

/* ========== TREE VIEW ========== */
QTreeView {
    background: white;
    border: 1px solid #e6ecf5;
    border-radius: 12px;
    padding: 4px;
    color: #2c3e50;
}

QTreeView::item {
    padding: 8px;
    border-radius: 6px;
}

QTreeView::item:hover {
    background: #f0f8ff;
}

QTreeView::item:selected {
    background: #e1f0fa;
    color: #2980b9;
}

/* ========== TAB BAR ========== */
QTabBar::close-button {
    image: none;
    background: #e6ecf5;
    border-radius: 8px;
    padding: 2px;
}

QTabBar::close-button:hover {
    background: #ff6b6b;
    color: white;
}

/* ========== SCROLL AREA ========== */
QScrollArea {
    border: 1px solid #e6ecf5;
    border-radius: 12px;
    background: white;
}

/* ========== DATE EDIT ========== */
QDateEdit {
    background: white;
    color: #2c3e50;
    border: 1px solid #d8e1ec;
    border-radius: 10px;
    padding: 8px 12px;
    font-size: 13px;
}

QDateEdit:hover {
    border: 1px solid #3498db;
}

QDateEdit:focus {
    border: 1px solid #2980b9;
}

/* ========== DIAL ========== */
QDial {
    background: transparent;
    color: #3498db;
}

QDial::handle {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                               stop:0 #ffffff,
                               stop:1 #f0f8ff);
    border: 2px solid #3498db;
    border-radius: 12px;
}

QDial::handle:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                               stop:0 #74b9ff,
                               stop:1 #3498db);
}</string>
